{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "status component tokens",
  "status": {
    "accessibility-background": {
      "$type": "color",
      "$description": "accessibility-background token",
      "$extensions": {
        "carbon.themes": {
          "white": "#ffffff",
          "g10": "#ffffff",
          "g90": "#161616",
          "g100": "#161616"
        }
      }
    },
    "blue": {
      "$type": "color",
      "$description": "blue token",
      "$extensions": {
        "carbon.themes": {
          "white": "#0043ce",
          "g10": "#0043ce",
          "g90": "#4589ff",
          "g100": "#4589ff"
        }
      }
    },
    "gray": {
      "$type": "color",
      "$description": "gray token",
      "$extensions": {
        "carbon.themes": {
          "white": "#6f6f6f",
          "g10": "#6f6f6f",
          "g90": "#8d8d8d",
          "g100": "#8d8d8d"
        }
      }
    },
    "green": {
      "$type": "color",
      "$description": "green token",
      "$extensions": {
        "carbon.themes": {
          "white": "#24a148",
          "g10": "#24a148",
          "g90": "#42be65",
          "g100": "#42be65"
        }
      }
    },
    "orange": {
      "$type": "color",
