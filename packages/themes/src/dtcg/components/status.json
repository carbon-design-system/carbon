    "purple": {
      "$type": "color",
      "$description": "purple token",
      "$extensions": {
        "carbon.themes": {
          "white": "#8a3ffc",
          "g10": "#8a3ffc",
          "g90": "#a56eff",
          "g100": "#a56eff"
