          "g10": "#ff832b",
          "g90": "#ff832b",
          "g100": "#ff832b"
        }
      }
    },
    "orange-outline": {
      "$type": "color",
      "$description": "orange-outline token",
      "$extensions": {
        "carbon.themes": {
          "white": "#ba4e00",
          "g10": "#ba4e00"
        }
      }
