{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "content-switcher component tokens",
  "content-switcher": {
    "background": {
      "$type": "color",
      "$description": "background token",
      "$extensions": {
        "carbon.themes": {
          "white": "{gray.20}",
          "g10": "{gray.20}",
          "g90": "{black.default}",
          "g100": "{black.default}"
        },
        "com.ibm.carbon": {
          "alphaModifiers": {
            "g90": 0,
            "g100": 0
          }
        }
      }
    },
    "background-hover": {
      "$type": "color",
      "$description": "background-hover token",
      "$extensions": {
        "carbon.themes": {
          "white": "{gray.20Hover}",
          "g10": "{gray.20Hover}",
          "g90": "{gray.50}",
          "g100": "{gray.50}"
        },
        "com.ibm.carbon": {
          "alphaModifiers": {
            "g90": 0.12,
            "g100": 0.12
          }
        }
      }
    },
    "selected": {
      "$type": "color",
      "$description": "selected token",
      "$extensions": {
        "carbon.themes": {
          "white": "{white.default}",
          "g10": "{white.default}",
          "g90": "{gray.50}",
          "g100": "{gray.50}"
        },
        "com.ibm.carbon": {
          "alphaModifiers": {
            "g90": 0.24,
            "g100": 0.24
          }
        }
      }
    }
  }
}
