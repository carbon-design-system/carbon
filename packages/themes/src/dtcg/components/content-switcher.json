{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "content-switcher component tokens",
  "content-switcher": {
    "background": {
      "$type": "color",
      "$description": "background token",
      "$extensions": {
        "carbon.themes": {
          "white": "#e0e0e0",
          "g10": "#e0e0e0",
          "g90": "rgba(0, 0, 0, 0)",
          "g100": "rgba(0, 0, 0, 0)"
        }
      }
    },
    "background-hover": {
      "$type": "color",
      "$description": "background-hover token",
      "$extensions": {
        "carbon.themes": {
          "white": "#d1d1d1",
          "g10": "#d1d1d1",
          "g90": "rgba(141, 141, 141, 0.12)",
          "g100": "rgba(141, 141, 141, 0.12)"
        }
      }
    },
    "selected": {
      "$type": "color",
      "$description": "selected token",
      "$extensions": {
        "carbon.themes": {
          "white": "#ffffff",
          "g10": "#ffffff",
          "g90": "rgba(141, 141, 141, 0.24)",
          "g100": "rgba(141, 141, 141, 0.24)"
        }
      }
    }
  }
}
