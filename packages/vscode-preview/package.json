{
  "name": "@carbon/vscode-preview",
  "description": "VS Code extension for previewing Carbon components styled for VS Code webviews",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "publisher": "carbon-design-system",
  "displayName": "Carbon Component Preview",
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "carbon.openPreview",
        "title": "Carbon: Open Component Preview",
        "icon": "$(preview)"
      }
    ],
    "configuration": {
      "title": "Carbon Component Preview",
      "properties": {
        "carbon.preview.storybookPort": {
          "type": "number",
          "default": 3000,
          "description": "Port of the running Carbon Storybook dev server (used for hot-reload in development)"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/carbon-design-system/carbon.git",
    "directory": "packages/vscode-preview"
  },
  "scripts": {
    "build": "yarn build:webview && yarn build:extension",
    "build:webview": "vite build --config vite.webview.config.ts",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "dev": "concurrently \"yarn dev:webview\" \"yarn dev:extension\"",
    "dev:webview": "vite build --config vite.webview.config.ts --watch",
    "dev:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@carbon/icons-react": "^11.75.0",
    "@carbon/react": "^1.101.0",
    "@carbon/styles": "^1.100.0",
    "@carbon/themes": "^11.68.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.20.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rimraf": "^5.0.0",
    "sass": "^1.70.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
