{
  "name": "@carbon/utilities-react",
  "description": "Utilities and helpers to drive consistency across software products using the Carbon Design System with React",
  "version": "0.21.0",
  "license": "Apache-2.0",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/carbon-design-system/carbon.git",
    "directory": "packages/utilities-react"
  },
  "bugs": "https://github.com/carbon-design-system/carbon/issues",
  "files": [
    "es",
    "lib",
    "telemetry.yml"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js",
      "default": "./es/index.js"
    },
    "./*": {
      "types": "./es/*/index.d.ts",
      "import": "./es/*/index.js",
      "require": "./lib/*/index.js",
      "default": "./es/*/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "ibm",
    "carbon",
    "carbon-design-system",
    "carbon-utilities",
    "carbon-react"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "yarn clean && tsdown --config tsdown.config.mts",
    "watch": "tsdown --config tsdown.config.mts --watch",
    "clean": "rimraf es lib types",
    "postinstall": "ibmtelemetry --config=telemetry.yml"
  },
  "peerDependencies": {
    "react": "^16.8.6 || ^17.0.1 || ^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsdown": "^0.21.0",
    "typescript-config-carbon": "workspace:^0.9.0"
  },
  "dependencies": {
    "@carbon/utilities": "^0.18.0",
    "@ibm/telemetry-js": "^1.6.1"
  }
}
