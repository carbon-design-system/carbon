{
  "name": "@carbon/utilities-react",
  "description": "Utilities and helpers to drive consistency across software products using the Carbon Design System with React",
  "version": "0.19.0",
  "license": "Apache-2.0",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/carbon-design-system/carbon.git",
    "directory": "packages/utilities-react"
  },
  "bugs": "https://github.com/carbon-design-system/carbon/issues",
  "files": [
    "es",
    "lib",
    "types",
    "telemetry.yml"
  ],
  "keywords": [
    "ibm",
    "carbon",
    "carbon-design-system",
    "carbon-utilities",
    "carbon-react"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build:types": "tsc",
    "build": "yarn clean && tsdown --config tsdown.config.ts && yarn build:types",
    "watch": "tsdown --config tsdown.config.ts --watch",
    "clean": "rimraf es lib",
    "postinstall": "ibmtelemetry --config=telemetry.yml"
  },
  "peerDependencies": {
    "react": "^16.8.6 || ^17.0.1 || ^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3",
    "typescript-config-carbon": "workspace:^0.9.0"
  },
  "dependencies": {
    "@carbon/utilities": "^0.16.0",
    "@ibm/telemetry-js": "^1.6.1"
  }
}
